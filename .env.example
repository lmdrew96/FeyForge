# FeyForge environment variables.
# Copy to .env.local and fill in. Never commit .env.local.

# ── Convex (backend / realtime DB) ────────────────────────────────────────────
# NEXT_PUBLIC_CONVEX_URL + CONVEX_DEPLOYMENT are set for you by `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
# Convex HTTP actions endpoint (Clerk webhooks, etc.).
NEXT_PUBLIC_CONVEX_SITE_URL=

# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# From clerk.com > your app > API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Routing — these defaults match the app's pages; change only if you move them.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Anthropic (AI features) ───────────────────────────────────────────────────
# Required for ALL AI routes: character build/name/backstory/traits/optimize and
# the character-creation assistant. Without it every AI feature 500s.
# Read implicitly by @ai-sdk/anthropic — must be named exactly ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=

# ── Cloudflare R2 (audio storage) ─────────────────────────────────────────────
# From cloudflare.com > your account > R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Resend (transactional email) ──────────────────────────────────────────────
# Optional in dev: without RESEND_API_KEY, reset/magic links are logged to console.
RESEND_API_KEY=
EMAIL_FROM=

# ── Ko-fi (premium webhook) ───────────────────────────────────────────────────
KOFI_VERIFICATION_TOKEN=

# ── Dev tooling ───────────────────────────────────────────────────────────────
# Shared secret guarding the library seed script. Optional unless you seed.
SEED_SECRET=
